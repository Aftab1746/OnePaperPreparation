# Copy this file to .env.local and fill in values from your Supabase project
# (Dashboard -> Project Settings -> API).

# Safe to expose to the browser (used by the client-side Supabase SDK):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NEVER expose this one to the browser — used only by scripts/seed-mcqs.cjs
# and any future server-only admin tools. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
